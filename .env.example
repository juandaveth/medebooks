# Copia este archivo a .env.local y completa los valores.
# La app funciona SIN estos valores (modo demo con datos de muestra).

# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo para el script de sembrado (NO subir, NO exponer al navegador):
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud → habilita "Places API (New)" y crea una API key
GOOGLE_MAPS_API_KEY=
